---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Hit Me Up — Eliyannah Amirah Yisrael"
  description="Direct contact, representation, press, and social."
  pageSlug="contact"
  pageNumber={8}
>

<main class="main">
  <section class="page">
    <div class="page-eyebrow">Section 08 · Contact</div>
    <h1 class="page-title">Hit <em>Me</em> Up.</h1>
    <p class="page-subtitle">
      One path. Direct. Use your real subject line.
    </p>

    <p class="contact-lead">
      For project conversations, representation inquiries, press, and the occasional <em>"we should meet."</em>
    </p>

    <div class="contact-grid">
      <div class="contact-block primary">
        <div class="contact-block-label">Direct</div>
        <div class="contact-block-value">
          <a href="mailto:me@eliyannah.direct">me@eliyannah.direct</a>
        </div>
        <div class="contact-block-note">I read every email. I answer most of them.</div>
      </div>

      <div class="contact-block">
        <div class="contact-block-label">Representation</div>
        <div class="contact-block-value" style="font-style: italic; color: var(--ink-mid);">
          Currently unsigned. Warm intros welcome.
        </div>
        <div class="contact-block-note">Agents, managers — write to the direct line above.</div>
      </div>

      <div class="contact-block">
        <div class="contact-block-label">Press &amp; Festivals</div>
        <div class="contact-block-value">
          <a href="/press">See the press kit →</a>
        </div>
        <div class="contact-block-note">Photos, bio, one-sheets, and interview request form.</div>
      </div>

      <div class="contact-block">
        <div class="contact-block-label">Newsletter</div>
        <div class="contact-block-value">
          <a href="/forest">From the Forest →</a>
        </div>
        <div class="contact-block-note">Monthly. Launches May 3. Subscribe there.</div>
      </div>
    </div>

    <div style="margin-top: 3rem;">
      <div class="press-archive-label">
        <span>Elsewhere on the Internet</span>
        <span class="sub">Follow / Watch / Read</span>
      </div>
      <div class="social-grid">
        <a href="https://instagram.com/eliyannahdirect" class="social-link" target="_blank" rel="noopener">
          <span class="platform">Instagram</span>
          <span class="handle">@eliyannahdirect</span>
        </a>
        <a href="https://www.youtube.com/@SunshineMoxie" class="social-link" target="_blank" rel="noopener">
          <span class="platform">YouTube</span>
          <span class="handle">@SunshineMoxie</span>
        </a>
        <a href="https://www.imdb.com/name/nm6607074/" class="social-link" target="_blank" rel="noopener">
          <span class="platform">IMDb</span>
          <span class="handle">Eliyannah A. Yisrael</span>
        </a>
        <a href="#" class="social-link">
          <span class="platform">The Forest</span>
          <span class="handle">forestofgodsanswers.com</span>
        </a>
      </div>
    </div>

  </section>
</main>

</BaseLayout>
