---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import { renderInline } from "../lib/render-prose";

const reader = createReader(process.cwd(), keystaticConfig);
const c = await reader.singletons.contact.read();

// Fallback so the page can never render empty if the file is missing.
const FALLBACK = {
  lead: 'For project conversations, representation inquiries, press, and the occasional *"we should meet."*',
  blocks: [
    { label: "Direct", value: "me@eliyannah.direct", link: "mailto:me@eliyannah.direct", note: "I read every email. I answer most of them.", highlight: true },
    { label: "Representation", value: "Currently unsigned. Warm intros welcome.", link: "", note: "Agents, managers — write to the direct line above.", highlight: false },
    { label: "Press & Festivals", value: "See the press kit →", link: "/press", note: "Photos, bio, one-sheets, and interview request form.", highlight: false },
    { label: "Newsletter", value: "From the Forest →", link: "/forest", note: "Monthly. Launches May 3. Subscribe there.", highlight: false },
  ],
  socialLabel: "Elsewhere on the Internet",
  socialSub: "Follow / Watch / Read",
  socials: [
    { platform: "Instagram", handle: "@eliyannahdirect", link: "https://instagram.com/eliyannahdirect" },
    { platform: "YouTube", handle: "@SunshineMoxie", link: "https://www.youtube.com/@SunshineMoxie" },
    { platform: "IMDb", handle: "Eliyannah A. Yisrael", link: "https://www.imdb.com/name/nm6607074/" },
    { platform: "The Forest", handle: "forestofgodsanswers.com", link: "" },
  ],
};

const data = c ?? FALLBACK;
const blocks = data.blocks?.length ? data.blocks : FALLBACK.blocks;
const socials = data.socials?.length ? data.socials : FALLBACK.socials;

function isExternal(href) {
  return typeof href === "string" && /^https?:\/\//.test(href);
}
---

<BaseLayout
  title="Hit Me Up — Eliyannah Amirah Yisrael"
  description="Direct contact, representation, press, and social."
  pageSlug="contact"
  pageNumber={8}
>

<main class="main">
  <section class="page">
    <div class="page-eyebrow">Section 08 · Contact</div>
    <h1 class="page-title">Hit <em>Me</em> Up.</h1>
    <p class="page-subtitle">
      One path. Direct. Use your real subject line.
    </p>

    <p class="contact-lead" set:html={renderInline(data.lead).html} />

    <div class="contact-grid">
      {blocks.map((block) => (
        <div class={block.highlight ? "contact-block primary" : "contact-block"}>
          <div class="contact-block-label" set:html={renderInline(block.label).html} />
          {block.link
            ? (
              <div class="contact-block-value">
                <a
                  href={block.link}
                  target={isExternal(block.link) ? "_blank" : undefined}
                  rel={isExternal(block.link) ? "noopener" : undefined}
                  set:html={renderInline(block.value).html}
                />
              </div>
            )
            : (
              <div class="contact-block-value" style="font-style: italic; color: var(--ink-mid);" set:html={renderInline(block.value).html} />
            )
          }
          {block.note && <div class="contact-block-note" set:html={renderInline(block.note).html} />}
        </div>
      ))}
    </div>

    <div style="margin-top: 3rem;">
      <div class="press-archive-label">
        <span>{data.socialLabel}</span>
        <span class="sub">{data.socialSub}</span>
      </div>
      <div class="social-grid">
        {socials.map((s) => (
          s.link
            ? (
              <a href={s.link} class="social-link" target={isExternal(s.link) ? "_blank" : undefined} rel={isExternal(s.link) ? "noopener" : undefined}>
                <span class="platform">{s.platform}</span>
                <span class="handle">{s.handle}</span>
              </a>
            )
            : (
              <div class="social-link">
                <span class="platform">{s.platform}</span>
                <span class="handle">{s.handle}</span>
              </div>
            )
        ))}
      </div>
    </div>

  </section>
</main>

</BaseLayout>
