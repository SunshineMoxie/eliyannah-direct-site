---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import { renderMarkdoc } from "../lib/render-markdoc";
import { renderInline, renderProse } from "../lib/render-prose";

// Read the Dailies entries straight from the files in the repo.
// This runs at build time on Netlify (a blessed place for the Reader API), so
// the public Dailies page stays fully static. When you save an edit in
// /keystatic, Keystatic commits to the repo, Netlify rebuilds, and this reruns.
const reader = createReader(process.cwd(), keystaticConfig);
const t = await reader.singletons.pageText.read();

const raw = await reader.collections.dailies.all();

// Resolve each Markdoc body to HTML and sort by entryNumber ascending
// (001 before 002), preserving the order the page shipped with.
const entries = (
  await Promise.all(
    raw.map(async ({ slug, entry }) => ({
      slug,
      title: entry.title,
      entryNumber: entry.entryNumber,
      location: entry.location,
      dateLine: entry.dateLine,
      bodyHtml: renderMarkdoc(await entry.body()),
    }))
  )
).sort((a, b) => a.entryNumber.localeCompare(b.entryNumber));
---

<BaseLayout
  title="Dailies — Eliyannah Amirah Yisrael"
  description="Short writing from the day. Notes, vocabulary, what's currently working."
  pageSlug="dailies"
  pageNumber={6}
>

<main class="main dailies-page">
  <section class="page" style="position:relative;">
    <div class="dailies-revision-stamp">Pink Revision · Rev 01</div>
    <div class="page-eyebrow">{t?.dailiesEyebrow || "Section 06 · Dailies — Pink Revision"}</div>
    <h1 class="page-title" set:html={renderInline(t?.dailiesTitle || "The *Dailies*").html} />
    <p class="page-subtitle" set:html={renderInline(t?.dailiesSubtitle || "Notes from the day. What I'm working on. What I just read. What I can't stop thinking about.").html} />

    <div class="dailies-intro" style="max-width: 720px; margin-bottom: 3rem;" set:html={renderProse(t?.dailiesIntro || 'On a production, *dailies* are the footage from the day — raw, current, proof that something happened. On this site, the dailies are short writing. The notebook that happens to be public.\n\nNot a blog. Not a newsletter. (The newsletter is *From the Forest*, and it lives elsewhere.) This is the place where the working vocabulary accumulates — "butterfly work," "Hood New Wave," "cinematic ministry" — and where short thoughts land before they are long ones.').html} />

    {entries.map((entry) => (
      <article class="dailies-entry">
        <div class="dailies-entry-header">
          <div class="dailies-entry-meta">
            <span class="number">Entry · {entry.entryNumber}</span>
            <span>{entry.location}</span>
            <span>{entry.dateLine}</span>
          </div>
        </div>
        <h2 class="dailies-entry-title">{entry.title}</h2>
        <div class="dailies-entry-body" set:html={entry.bodyHtml} />
      </article>
    ))}

  </section>
</main>

</BaseLayout>

<style>
  .dailies-intro p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink-soft);
  }
  .dailies-intro p + p { margin-top: 1rem; }
</style>
