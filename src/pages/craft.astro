---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import { renderInline, renderProse } from "../lib/render-prose";

const reader = createReader(process.cwd(), keystaticConfig);
const rawCraft = await reader.collections.craft.all();
const t = await reader.singletons.pageText.read();

const items = rawCraft
  .map(({ entry }) => entry)
  .sort((a, b) => (a.number || "").localeCompare(b.number || ""));
---

<BaseLayout
  title="Craft Services — Eliyannah Amirah Yisrael"
  description="The fun room. Recipes, reading, playlists, Chicago, YouTube."
  pageSlug="craft"
  pageNumber={7}
>

<main class="main">
  <section class="page">
    <div class="page-eyebrow">{t?.craftEyebrow || "Section 07 · Craft Services"}</div>
    <h1 class="page-title" set:html={renderInline(t?.craftTitle || "Craft *Services*").html} />
    <p class="page-subtitle" set:html={renderInline(t?.craftSubtitle || "The table in the hallway. Where the crew actually meets each other.").html} />

    <p style="max-width: 640px; font-size: 1.05rem; line-height: 1.7; color: var(--ink-soft); margin-bottom: 2rem;" set:html={renderInline(t?.craftIntro || "On a set, craft services is where you figure out who everybody is. Here: the things outside the work that are still very much the work. The recipes. The books. The playlists. The Chicago spots. A room kept deliberately fun on a serious site.").html} />

    <div class="craft-menu">
      {items.map((item) => {
        const title = renderInline(item.title);
        const body = renderProse(item.body);
        return (
          <div class="craft-item">
            <div class="craft-item-number">{item.number}</div>
            <div class="craft-item-label">{item.label}</div>
            <h3 class="craft-item-title" set:html={title.html} />
            {body.prompt
              ? <div class="craft-item-body"><span class="prompt" set:html={body.html} /></div>
              : <div class="craft-item-body" set:html={body.html} />}
          </div>
        );
      })}
    </div>
  </section>
</main>

</BaseLayout>
