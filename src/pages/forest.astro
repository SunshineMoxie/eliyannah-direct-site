---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import { renderInline, renderProse } from "../lib/render-prose";

const reader = createReader(process.cwd(), keystaticConfig);
const f = await reader.singletons.forest.read();

const intro = renderProse(f?.intro);
---

<BaseLayout
  title="The Forest of God's Answers — Eliyannah Amirah Yisrael"
  description="The parent company. The ecosystem. The copses inside the forest."
  pageSlug="forest"
  pageNumber={4}
>

<main class="main forest-page">
  <section class="page">
    <div class="page-eyebrow">Section 04 · The Parent Company</div>
    <h1 class="page-title" set:html={renderInline(f?.title).html} />
    <p class="page-subtitle" set:html={renderInline(f?.subtitle).html} />

    <div class="forest-intro">
      <div class="forest-intro-lead">
        <Fragment set:html={intro.html} />
        {f?.introEmphasis && (
          <p class="emphasis" set:html={renderInline(f.introEmphasis).html} />
        )}
      </div>

      <aside class="forest-etymology">
        <div class="label">{f?.etymology?.label}</div>
        <div class="word">{f?.etymology?.word}</div>
        <div class="pronunciation">{f?.etymology?.pronunciation}</div>
        <div class="meaning" set:html={renderInline(f?.etymology?.meaning).html} />
        <div class="translates-to" set:html={renderInline(f?.etymology?.translatesTo).html} />
      </aside>
    </div>

    <!-- Copses -->
    <div class="copses-section">
      <div class="copses-heading">{f?.copsesHeading}</div>
      <h2 class="copses-title" set:html={renderInline(f?.copsesTitle).html} />
      <p class="copses-intro" set:html={renderInline(f?.copsesIntro).html} />

      <div class="copses-grid">
        {f?.copses?.map((copse) => (
          <div class={copse.current ? "copse-card is-current" : "copse-card"}>
            <div class="copse-card-header">
              <span class="copse-card-number">{copse.number}</span>
              <span class={copse.inMotion ? "copse-card-status in-motion" : "copse-card-status"}>{copse.status}</span>
            </div>
            <h3 class="copse-card-name" set:html={renderInline(copse.name).html} />
            <div class="copse-card-tagline" set:html={renderInline(copse.tagline).html} />
            <div class="copse-card-blurb" set:html={renderInline(copse.blurb).html} />
            <div class="copse-card-brands">
              <strong>Inside The Copse</strong>
              {copse.brands}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Signup -->
    <div class="signup-block">
      <div class="signup-block-eyebrow">{f?.signupEyebrow}</div>
      <h2 class="signup-block-title" set:html={renderInline(f?.signupTitle).html} />
      <p class="signup-block-body" set:html={renderInline(f?.signupBody).html} />
      <form class="signup-form" action="https://buttondown.com/api/emails/embed-subscribe/theforestofgodsanswers" method="post" target="popupwindow">
        <input type="email" name="email" placeholder="Your best email" aria-label="Email address" required>
        <button type="submit">Subscribe</button>
      </form>
      <div class="signup-footnote">{f?.signupFootnote}</div>
    </div>

    <!-- Branch letters grid -->
    <div class="branches-section">
      <div class="copses-heading">{f?.branchesHeading}</div>
      <h2 class="copses-title" set:html={renderInline(f?.branchesTitle).html} />
      <p class="copses-intro" set:html={renderInline(f?.branchesIntro).html} />

      <div class="branches-grid">
        {f?.branches?.map((branch) => (
          <div class={branch.mothership ? "branch-cell mothership" : "branch-cell"}>
            <div class="branch-type">{branch.type}</div>
            <div class="branch-name" set:html={renderInline(branch.name).html} />
            <div class="branch-status">{branch.status}</div>
            <div class="branch-desc" set:html={renderInline(branch.desc).html} />
          </div>
        ))}
      </div>
    </div>

  </section>
</main>

</BaseLayout>
