---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import { renderPanelValue } from "../lib/render-text";

// Read the four status panels from the Keystatic singleton at build time.
// If the file is ever missing or unreadable, we fall back to the known copy so
// the landing page can never render with empty panels.
const reader = createReader(process.cwd(), keystaticConfig);
const status = await reader.singletons.callSheetStatus.read();

const FALLBACK_PANELS = [
  { label: "Current Production", value: "*The Caterpillar and The Butterfly*", sub: "Feature · In Development", highlight: false },
  { label: "Status", value: "Actively Pitching", sub: "Actors · Producers · Agents", highlight: false },
  { label: "Based In", value: "Chicago & LA", sub: "Will Travel For Work", highlight: false },
  { label: "Now On Deck", value: "From The *Forest*", sub: "Newsletter · Launches May 3", highlight: true },
];

const panels = status?.panels?.length ? status.panels : FALLBACK_PANELS;
---

<BaseLayout
  title="Eliyannah Amirah Yisrael — Writer / Director"
  description="The working site of Eliyannah Amirah Yisrael. Writer, director. A Sunshine Moxie Production under The Forest of God's Answers."
  pageSlug="call-sheet"
  pageNumber={1}
>

<main class="main">
  <section class="page">

    <!-- Hero -->
    <div class="call-sheet-hero">
      <div class="call-sheet-lead">
        <div class="call-sheet-production-line">Production · Writer / Director · Est. Chicago</div>

        <h1 class="call-sheet-name">
          <span class="line-1">Eliyannah</span>
          <span class="line-2">Amirah</span>
          <span class="line-3">Yisrael</span>
        </h1>

        <div class="call-sheet-role">A working director. A Chicago storyteller.</div>

        <div class="call-sheet-statement">
          <p>I make Hood New Wave cinema for Black America. Films with the formal seriousness of Italian Neorealism and the raw subjectivity of a Drill-era music video, shot on film, for the people the films are about. My focus is the Black Midwest, the region too often left out of the story of Black America. The stories of Black America deserve high art the people who live those stories can actually watch. That is what the work is for.</p>
        </div>

        <div class="call-sheet-cta">
          <a href="/work" class="btn primary">See The Work →</a>
          <a href="/crew" class="btn">Meet The Crew</a>
          <a href="/contact" class="btn yellow">Hit Me Up</a>
        </div>
      </div>

      <div class="hero-image-frame">
        <div class="hero-image-placeholder">
          <div class="icon">01 / A</div>
          <div class="label">Hero Image Slot</div>
          <div class="instruction">Your strongest single still or portrait. A frame from Caterpillar, a BTS still you love, or the Sunshine Moxie photo you've always loved. One image at the top of the call sheet.</div>
        </div>
        <div class="image-caption">
          <span>HERO · 01A</span>
          <span>35MM / DIGITAL</span>
        </div>
      </div>
    </div>

    <!-- Production info panels (now editable via /keystatic) -->
    <div class="production-info">
      {panels.map((panel) => (
        <div class={panel.highlight ? "info-panel weather" : "info-panel"}>
          <div class="label">{panel.label}</div>
          <div class="value" set:html={renderPanelValue(panel.value)} />
          <div class="sub">{panel.sub}</div>
        </div>
      ))}
    </div>

    <!-- Scheduled scenes -->
    <div class="scheduled-scenes-title">
      <span>Scenes Scheduled Today</span>
      <span class="count">04 on the call</span>
    </div>

    <a href="/work" class="scheduled-row">
      <span class="scene-number">SC 02</span>
      <div class="scene-title">Scenes <em>/ The Work</em></div>
      <div class="scene-description">Feature, webseries, commercial, music video. The working filmography, scene by scene.</div>
      <div class="scene-type">NARRATIVE</div>
      <div class="scene-arrow">Open →</div>
    </a>

    <a href="/crew" class="scheduled-row">
      <span class="scene-number">SC 03</span>
      <div class="scene-title">Crew <em>/ About</em></div>
      <div class="scene-description">Above the line, below the line, references, continuity. The director in full.</div>
      <div class="scene-type">CREW LIST</div>
      <div class="scene-arrow">Open →</div>
    </a>

    <a href="/forest" class="scheduled-row">
      <span class="scene-number">SC 04</span>
      <div class="scene-title">The <em>Forest</em></div>
      <div class="scene-description">The parent company. The ecosystem. What I mean when I say I'm building.</div>
      <div class="scene-type">PARENT CO</div>
      <div class="scene-arrow">Open →</div>
    </a>

    <a href="/contact" class="scheduled-row">
      <span class="scene-number">SC 08</span>
      <div class="scene-title">Hit <em>Me Up</em></div>
      <div class="scene-description">Representation inquiries, project conversations, press. One clean path.</div>
      <div class="scene-type">CONTACT</div>
      <div class="scene-arrow">Open →</div>
    </a>

    <!-- From the Forest signup block -->
    <div class="signup-block">
      <div class="signup-block-eyebrow">The Mothership · Monthly</div>
      <h2 class="signup-block-title">
        <em>From the Forest</em> — dispatches from the woman doing the building.
      </h2>
      <p class="signup-block-body">
        A personal letter from Eliyannah, once a month. What she's writing, directing, building, and reading. Cultural commentary, behind-the-scenes, the view from inside the forest. Launches May 3.
      </p>
      <form class="signup-form" action="https://buttondown.com/api/emails/embed-subscribe/theforestofgodsanswers" method="post" target="popupwindow">
        <input type="email" name="email" placeholder="Your best email" aria-label="Email address" required>
        <button type="submit">Subscribe</button>
      </form>
      <div class="signup-footnote">No spam. Just the newsletter. Unsubscribe anytime.</div>
    </div>

    <!-- Notes strip -->
    <div class="notes-strip">
      <p>This site is a working document. A call sheet. A binder kept by a director who takes production seriously and takes her own joy seriously. Pages will be added. Scenes will be revised. The pink page means the revision matters.</p>
      <div class="signature">— E.A.Y., Producer of the Day</div>
    </div>

  </section>
</main>

</BaseLayout>
