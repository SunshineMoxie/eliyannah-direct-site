---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";
import { renderInline, renderProse } from "../lib/render-prose";

const reader = createReader(process.cwd(), keystaticConfig);
const rawScenes = await reader.collections.scenes.all();

const scenes = rawScenes
  .map(({ entry }) => entry)
  .sort((a, b) => (a.sceneNumber || "").localeCompare(b.sceneNumber || ""));
---

<BaseLayout
  title="Scenes / The Work — Eliyannah Amirah Yisrael"
  description="The working filmography of Eliyannah Amirah Yisrael. Feature, webseries, commercial, and music video credits."
  pageSlug="scenes"
  pageNumber={2}
>

<main class="main">
  <section class="page">
    <div class="page-eyebrow">Section 02 · Scenes</div>
    <h1 class="page-title">The <em>Work</em></h1>
    <p class="page-subtitle">
      Every project is a scene. Every scene is the whole argument for what comes next.
    </p>

    <div class="scenes-grid">
      {scenes.map((scene) => {
        const title = renderInline(scene.title);
        const tagline = renderInline(scene.tagline);
        const synopsis = renderProse(scene.synopsis);
        return (
          <article class="scene-entry">
            <div class="scene-entry-number">{scene.sceneNumber}</div>
            <div class="scene-entry-body">
              <div class="scene-entry-main">
                {scene.slugline && <div class="scene-slugline">{scene.slugline}</div>}
                <h2 class="scene-entry-title" set:html={title.html} />
                {scene.tagline && (
                  tagline.prompt
                    ? <div class="scene-entry-tagline"><span class="prompt small" set:html={tagline.html} /></div>
                    : <div class="scene-entry-tagline" set:html={tagline.html} />
                )}
                {scene.synopsis && (
                  synopsis.prompt
                    ? <div class="scene-entry-synopsis"><span class="prompt" set:html={synopsis.html} /></div>
                    : <div class="scene-entry-synopsis" set:html={synopsis.html} />
                )}
                {scene.actions && scene.actions.length > 0 && (
                  <div class="scene-entry-actions">
                    {scene.actions.map((a) => {
                      const href = a.href || "#";
                      const external = href.startsWith("http");
                      return (
                        <a
                          href={href}
                          class={a.primary ? "primary" : undefined}
                          target={external ? "_blank" : undefined}
                          rel={external ? "noopener" : undefined}
                        >{a.label}</a>
                      );
                    })}
                  </div>
                )}
              </div>
              {scene.meta && scene.meta.length > 0 && (
                <aside class="scene-entry-meta">
                  {scene.meta.map((row) => (
                    <div class="scene-meta-row">
                      <span class="key">{row.key}</span>
                      <span class="val" set:html={renderInline(row.value).html} />
                    </div>
                  ))}
                </aside>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </section>
</main>

</BaseLayout>
