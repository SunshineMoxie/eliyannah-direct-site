---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from "@keystatic/core/reader";
import keystaticConfig from "../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);
const rawPress = await reader.collections.press.all();
const clippings = rawPress.map(({ entry }) => entry);

// Fixed category display order. Each section only renders if it has entries.
const CATEGORY_ORDER = ["Print", "Video", "Audio", "Appearances"];
const grouped = CATEGORY_ORDER.map((cat) => ({
  category: cat,
  items: clippings
    .filter((c) => c.category === cat)
    .sort((a, b) => (a.sortOrder ?? 100) - (b.sortOrder ?? 100)),
})).filter((g) => g.items.length > 0);
---

<BaseLayout
  title="Press — Eliyannah Amirah Yisrael"
  description="Press coverage, interview requests, and the press kit."
  pageSlug="press"
  pageNumber={5}
>

<main class="main">
  <section class="page">
    <div class="page-eyebrow">Section 05 · Press</div>
    <h1 class="page-title">The <em>Notes</em> Page</h1>
    <p class="page-subtitle">
      What the serious outlets have said so far.
    </p>

    <p class="press-intro">
      Most of the press below was earned for Hermione Granger and the Quarter Life Crisis. The coverage is older than ideal. The fact that the outlets are <em>real</em>, and that their coverage was, too, is what matters. More is coming. Journalists, this page will be active again soon.
    </p>

    {grouped.map((group) => (
      <>
        <div class="press-archive-label">
          <span>{group.category}</span>
          <span class="sub">{group.items.length} {group.items.length === 1 ? "entry" : "entries"}</span>
        </div>
        <div class="press-clippings">
          {group.items.map((clip) => (
            <a href={clip.link || "#"} class="press-clip" target="_blank" rel="noopener">
              <div class="press-clip-outlet">{clip.outlet}</div>
              <div class="press-clip-date">{clip.date}</div>
              <div class="press-clip-quote">{clip.title}</div>
              <div class="press-clip-project">{clip.project}</div>
            </a>
          ))}
        </div>
      </>
    ))}

    <div class="press-kit">
      <div class="press-kit-label">For Journalists, Festivals &amp; Industry</div>
      <h3>The <em>Press Kit</em></h3>
      <p>
        Press photos, one-sheet bio, one-sheet filmography, and Sunshine Moxie / Forest of God's Answers brand assets. For festival programmers, journalists, and anyone building an event page, poster, or article.
      </p>
      <div class="press-kit-links">
        <a href="#">Download Press Kit (ZIP)</a>
        <a href="#">Press Photos Only</a>
        <a href="#">Bio (One Sheet)</a>
        <a href="mailto:me@eliyannah.direct">Request an Interview</a>
      </div>
    </div>

  </section>
</main>

</BaseLayout>
