---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Press — Eliyannah Amirah Yisrael"
  description="Press coverage, interview requests, and the press kit."
  pageSlug="press"
  pageNumber={5}
>

<main class="main">
  <section class="page">
    <div class="page-eyebrow">Section 05 · Press</div>
    <h1 class="page-title">The <em>Notes</em> Page</h1>
    <p class="page-subtitle">
      What the serious outlets have said so far.
    </p>

    <p class="press-intro">
      Most of the press below was earned for Hermione Granger and the Quarter Life Crisis in 2016–17. The coverage is older than ideal. The fact that the outlets are <em>real</em> — and that their coverage was, too — is what matters. More is coming. Journalists, this page will be active again soon.
    </p>

    <div class="press-archive-label">
      <span>Press Archive</span>
      <span class="sub">2016 — Present</span>
    </div>

    <div class="press-clippings">

      <a href="#" class="press-clip">
        <div class="press-clip-outlet">PBS</div>
        <div class="press-clip-quote">
          <span class="prompt small">Paste the actual pull quote from the PBS coverage. Keep it to one sentence.</span>
        </div>
        <div class="press-clip-date">Feature · 2017</div>
        <div class="press-clip-project">Hermione Granger and the Quarter Life Crisis</div>
      </a>

      <a href="#" class="press-clip">
        <div class="press-clip-outlet">Emmy Magazine</div>
        <div class="press-clip-quote">
          <span class="prompt small">The Emmy pull quote goes here.</span>
        </div>
        <div class="press-clip-date">Feature · 2017</div>
        <div class="press-clip-project">Hermione Granger and the Quarter Life Crisis</div>
      </a>

      <a href="#" class="press-clip">
        <div class="press-clip-outlet">The Los Angeles Times</div>
        <div class="press-clip-quote">
          <span class="prompt small">The LA Times pull quote.</span>
        </div>
        <div class="press-clip-date">Feature · 2016</div>
        <div class="press-clip-project">Hermione Granger and the Quarter Life Crisis</div>
      </a>

      <a href="#" class="press-clip">
        <div class="press-clip-outlet">Elle UK</div>
        <div class="press-clip-quote">
          <span class="prompt small">The Elle UK pull quote.</span>
        </div>
        <div class="press-clip-date">Feature · 2017</div>
        <div class="press-clip-project">Hermione Granger and the Quarter Life Crisis</div>
      </a>

    </div>

    <div class="press-kit">
      <div class="press-kit-label">For Journalists, Festivals &amp; Industry</div>
      <h3>The <em>Press Kit</em></h3>
      <p>
        Press photos, one-sheet bio, one-sheet filmography, and Sunshine Moxie / Forest of God's Answers brand assets. For festival programmers, journalists, and anyone building an event page, poster, or article.
      </p>
      <div class="press-kit-links">
        <a href="#">Download Press Kit (ZIP)</a>
        <a href="#">Press Photos Only</a>
        <a href="#">Bio (One Sheet)</a>
        <a href="mailto:me@eliyannah.direct">Request an Interview</a>
      </div>
    </div>

  </section>
</main>

</BaseLayout>
